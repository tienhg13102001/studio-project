{
	email admin@beezvn.com
}

beezvn.com, www.beezvn.com {
	encode zstd gzip

	# Trust Cloudflare so real client IPs are logged
	# (Cloudflare proxy is enabled — cf_tags=cf-proxied:true)
	# Refresh ranges occasionally if needed.

	# Backend API
	handle /api/* {
		reverse_proxy backend:4000
	}

	# Static assets served by backend (uploaded images/videos)
	handle /images/* {
		reverse_proxy backend:4000
	}
	handle /videos/* {
		reverse_proxy backend:4000
	}

	# Everything else → frontend SPA
	handle {
		reverse_proxy frontend:80
	}
}
